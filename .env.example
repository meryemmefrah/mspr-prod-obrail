# ============================================================
# .env.example - ObRail Europe (mise en production)
# ============================================================
# Ce fichier sert de MODELE. Il documente toutes les variables
# d'environnement attendues par la solution, SANS contenir de
# secret réel.
#
# Pour démarrer le projet :
#   1. Copier ce fichier :   cp .env.example .env
#   2. Renseigner des valeurs adaptées (mots de passe robustes en prod).
#
# Le fichier .env (avec les vraies valeurs) est ignoré par git.
# ============================================================

# ------------------------------------------------------------
# Base de données PostgreSQL
# ------------------------------------------------------------
# DB_HOST :
#   - "localhost" si on lance l'API hors Docker.
#   - "postgres"  (nom du service docker-compose) si on lance via Docker.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=obrail
DB_USER=postgres
# /!\ En production, remplacer par un mot de passe fort et unique.
DB_PASSWORD=change_me_in_production

# ------------------------------------------------------------
# Configuration de l'API
# ------------------------------------------------------------
# Origines autorisées pour le frontend (CORS), séparées par des virgules.
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Niveau de logs de l'application : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Frontend (React / Vite)
# ------------------------------------------------------------
# URL publique de l'API consommée par le frontend.
VITE_API_BASE_URL=http://localhost:8000

# ------------------------------------------------------------
# Monitoring (Grafana)
# ------------------------------------------------------------
# Identifiants de l'interface d'administration Grafana.
GRAFANA_ADMIN_USER=admin
# /!\ En production, remplacer par un mot de passe fort.
GRAFANA_ADMIN_PASSWORD=change_me_in_production
