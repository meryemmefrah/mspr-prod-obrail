{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Disponibilité de l'API",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "En ligne", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "Hors ligne", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "expr": "up{job=\"obrail-api\"}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 2,
      "title": "Requêtes par seconde",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"obrail-api\"}[1m]))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 3,
      "title": "Taux d'erreurs (5xx)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"obrail-api\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"obrail-api\"}[5m])), 1)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 4,
      "title": "Total des requêtes traitées",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"obrail-api\"})",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 5,
      "title": "Latence des réponses (percentiles)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"obrail-api\"}[5m])) by (le))",
          "legendFormat": "Médiane (p50)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"obrail-api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"obrail-api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 6,
      "title": "Requêtes par code de statut HTTP",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"obrail-api\"}[1m])) by (status)",
          "legendFormat": "Statut {{status}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 7,
      "title": "Requêtes par endpoint",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 } } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"obrail-api\"}[1m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["obrail", "api", "supervision"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "title": "ObRail Europe — Supervision de l'API",
  "uid": "obrail-api-monitoring",
  "version": 1
}
