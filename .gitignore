# ============================================================
# .gitignore - ObRail Europe (mise en production)
# ============================================================

# --- Secrets et variables d'environnement ---
# Le .env contient des identifiants : il ne doit JAMAIS être versionné.
# On versionne uniquement .env.example (sans valeurs sensibles).
.env
.env.local
*.env
!.env.example

# --- Python ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Node / React (frontend) ---
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Tests E2E ---
frontend/cypress/videos/
frontend/cypress/screenshots/
playwright-report/
test-results/

# --- Docker ---
# Les volumes nommés sont gérés par Docker, pas besoin de les ignorer ici,
# mais on ignore d'éventuels dumps locaux.
*.dump

# --- Monitoring (données runtime de Prometheus / Grafana) ---
monitoring/prometheus/data/
monitoring/grafana/data/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Logs ---
*.log
logs/
